{
  "name": "@bwo-ui/core",
  "version": "0.2.1",
  "description": "Framework-agnostic GSAP motion factories used by @bwo-ui/{react,vue,svelte}.",
  "license": "MIT",
  "author": "BOOGIE WOOGIE S.R.L. <contact@boogie.ro>",
  "homepage": "https://github.com/BoogieCode/bwo-ui/tree/master/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/BoogieCode/bwo-ui.git",
    "directory": "packages/core"
  },
  "keywords": [
    "gsap",
    "animation",
    "motion",
    "scroll",
    "marquee",
    "magnetic",
    "flip",
    "splittext"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/index.css",
    "./styles/*": "./styles/*"
  },
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "gsap": ">=3.12.0"
  },
  "devDependencies": {
    "gsap": "^3.12.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "rimraf": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
