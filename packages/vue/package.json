{
  "name": "@bwo-ui/vue",
  "version": "0.2.1",
  "description": "Vue 3 components and composables for GSAP-powered motion: SplitReveal, Magnetic, Marquee, FlipList.",
  "license": "MIT",
  "author": "BOOGIE WOOGIE S.R.L. <contact@boogie.ro>",
  "homepage": "https://github.com/BoogieCode/bwo-ui/tree/master/packages/vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/BoogieCode/bwo-ui.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "vue3",
    "gsap",
    "animation",
    "motion",
    "scroll",
    "marquee",
    "magnetic",
    "flip"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@bwo-ui/core": "workspace:*",
    "reka-ui": "^1.0.0-alpha.7"
  },
  "peerDependencies": {
    "gsap": ">=3.12.0",
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "gsap": "^3.12.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.5.13",
    "vitest": "^2.1.8",
    "rimraf": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
